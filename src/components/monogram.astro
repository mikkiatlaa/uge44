---
// LogoMonogram.astro
// Repeating tiled "UGE 44 LIV & DØD" pattern used as a decorative background/divider
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["logo-monogram", className]}>
  <svg width="100%" height="250" viewBox="0 0 1512 250" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" preserveAspectRatio="xMidYMid slice">
    <mask id="mask0_monogram" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="1512" height="250">
      <rect width="1512" height="250" fill="#D9D9D9"></rect>
    </mask>
    <g mask="url(#mask0_monogram)">
      <rect x="-264" y="138.603" width="300" height="300" transform="rotate(-43.7894 -264 138.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="-80" y="222.603" width="300" height="300" transform="rotate(-43.7894 -80 222.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="103" y="306.603" width="300" height="300" transform="rotate(-43.7894 103 306.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="287" y="390.603" width="300" height="300" transform="rotate(-43.7894 287 390.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="-73" y="-44.397" width="300" height="300" transform="rotate(-43.7894 -73 -44.397)" fill="url(#pattern_monogram)"></rect>
      <rect x="111" y="39.603" width="300" height="300" transform="rotate(-43.7894 111 39.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="294" y="123.603" width="300" height="300" transform="rotate(-43.7894 294 123.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="485" y="-60.397" width="300" height="300" transform="rotate(-43.7894 485 -60.397)" fill="url(#pattern_monogram)"></rect>
      <rect x="671" y="22.603" width="300" height="300" transform="rotate(-43.7894 671 22.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="861" y="103.603" width="300" height="300" transform="rotate(-43.7894 861 103.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="1052" y="-79.397" width="300" height="300" transform="rotate(-43.7894 1052 -79.397)" fill="url(#pattern_monogram)"></rect>
      <rect x="1241" y="2.60303" width="300" height="300" transform="rotate(-43.7894 1241 2.60303)" fill="url(#pattern_monogram)"></rect>
      <rect x="1427" y="85.603" width="300" height="300" transform="rotate(-43.7894 1427 85.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="1048" y="185.603" width="300" height="300" transform="rotate(-43.7894 1048 185.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="1234" y="268.603" width="300" height="300" transform="rotate(-43.7894 1234 268.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="478" y="207.603" width="300" height="300" transform="rotate(-43.7894 478 207.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="668" y="288.603" width="300" height="300" transform="rotate(-43.7894 668 288.603)" fill="url(#pattern_monogram)"></rect>
      <rect x="855" y="370.603" width="300" height="300" transform="rotate(-43.7894 855 370.603)" fill="url(#pattern_monogram)"></rect>
    </g>
    <defs>
      <pattern id="pattern_monogram" patternContentUnits="objectBoundingBox" width="1" height="1">
        <use xlink:href="#image_monogram" transform="matrix(0.00385983 0 0 0.0038588 -0.394851 -0.362286)"></use>
      </pattern>
      <image
        id="image_monogram"
        width="500"
        height="500"
        preserveAspectRatio="none"
        xlink:href="data:image/png;base64, CBAgQIECgLwGB3oeYAAEC5Qo4Eq6NhsAKJiDQV7AH7obrEHAIOAQcAssngkBfPp+rGxUBAgQIlCtQ4oAj4hL30OoIECBAgACBagkI9GrhWzcBAgQIECBQTwGBXh9pRyNA gAABAgQKFnCEXuCGmToBAgQIECBQKwGBXquVC wQIECBQqIBAL1DDTJUAAQIE CBConYBAr93GJQIECBAgUKhAQQICvUDtMlUCBAgQIECg5gICveYalwgQIECg "
      />
    </defs>
  </svg>
</div>

<style>
  .logo-monogram {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
  .logo-monogram svg {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
