---
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["monogram", className]}>
  <img src="/uge44monogram.webp.webp" alt="orange logo monogram" class="monogram-img" />
</div>

<style>
  .monogram {
    width: 100%;
    overflow: hidden;
  }

  .monogram img {
    width: 100%;
    height: 160px; /* samme højde som før */
    object-fit: cover; /* beskærer billedet pænt */
    display: block;
  }
</style>
